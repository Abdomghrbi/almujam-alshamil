# backend
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/almujam
# Database TLS: paste the provider's CA certificate (PEM) to verify the DB
# server's certificate. Recommended for hosted Postgres (e.g. Supabase),
# whose CA isn't in the system trust store. Example (single line, \n-joined):
#   DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
DATABASE_CA_CERT=
# Escape hatch ONLY if you can't provide DATABASE_CA_CERT yet: set to "true"
# to skip DB certificate verification (insecure — temporary use only).
DB_SSL_INSECURE=
JWT_SECRET=your-secret-key-here
# Exact origin of the frontend (e.g. https://app.example.com). Used for OAuth
# redirects, password-reset links, AND the CORS allow-origin — which must be a
# specific origin (not "*") so the browser will send the httpOnly auth cookie.
FRONTEND_URL=http://localhost:3000
# Set NODE_ENV=production in production so the session cookie is sent with
# Secure + SameSite=None (required when the frontend and API are on different
# origins over HTTPS). In development it uses SameSite=Lax over http.
NODE_ENV=development
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# AI ChatBot (Groq API)
GROQ_API_KEY=gsk_your-groq-api-key-here
